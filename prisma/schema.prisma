generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Account Related Models
model Account {
  id           String            @id @default(uuid())
  fullname     String
  email        String            @unique
  password     String
  phone        String
  role         String            @default("storeowner")
  AuthToken    AuthToken[]
  OTPCode      OTPCode[]
  verifiedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model AuthToken {
  id           String            @id @default(uuid())
  accountId    String
  token        String            @unique
  accounts     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([accountId])
  @@index([expiresAt])
}

model OTPCode {
  id           String            @id @default(uuid())
  accountId   String
  code         String
  accounts     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expires_at   DateTime
  isSuccess    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([accountId])
  @@index([expires_at])
}