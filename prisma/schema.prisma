generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Account Related Models
model Account {
  id           String            @id @default(uuid()) @unique
  fullname     String
  email        String            @unique
  password     String
  phone        String
  role         String            @default("storeowner")
  AuthToken    AuthToken[]
  OtpCode      OtpCode[]
  Store        Store[]
  verifiedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model AuthToken {
  id           String            @id @default(uuid()) @unique
  accountId    String
  token        String            @unique
  accounts     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([accountId])
  @@index([expiresAt])
}

model OtpCode {
  id           String            @id @default(uuid()) @unique
  accountId    String
  code         Int
  accounts     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  isSuccess    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([accountId])
  @@index([expiresAt])
}

// Store related models
model Store {
  id           String            @id @default(uuid()) @unique
  accountId    String
  account      Account           @relation(fields: [accountId], references: [id])
  name         String
  description  String
  logo_url     String?
  subdomain    String            @unique
  domain       String            @unique
  status       String            @default("active")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([subdomain])
  @@index([domain])
}