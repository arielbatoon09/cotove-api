generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Account Related Models
model Account {
  id           String            @id @default(uuid())
  fullname     String
  email        String            @unique
  password     String
  phone        String
  role         String            @default("storeowner")
  auth_token   AuthToken[]
  otp_code     OTPCode[]
  verified_at  DateTime?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
}

model AuthToken {
  id           String            @id @default(uuid())
  account_id   String
  token        String            @unique
  accounts     Account           @relation(fields: [account_id], references: [id], onDelete: Cascade)
  expiresAt    String
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  @@index([account_id])
  @@index([expiresAt])
}

model OTPCode {
  id           String            @id @default(uuid())
  account_id   String
  code         String
  accounts     Account           @relation(fields: [account_id], references: [id], onDelete: Cascade)
  expires_at   DateTime
  isSuccess    Int               @default(0)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  @@index([account_id])
  @@index([expires_at])
}